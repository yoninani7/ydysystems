---
alwaysApply: true
---

render: (v, row) => {
                    const days = parseInt(row.days);
                    if (v === 'Extended') return b('warning', 'Extended');
                    if (days < 14) return b('danger', 'Ending Soon');
                    if(days<=0)return b('warning', 'Ending Soon');
                    return b('info', 'Active');
                }
